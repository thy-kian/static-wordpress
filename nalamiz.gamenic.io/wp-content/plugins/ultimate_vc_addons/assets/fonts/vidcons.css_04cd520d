@font-face {
	font-family: 'ult-vid-cntrl';
	src:url('/wp-content/plugins/ultimate_vc_addons/assets/fonts/ult-vid-cntrl.eot_33ace239');
	src:url('/wp-content/plugins/ultimate_vc_addons/assets/fonts/ult-vid-cntrl.eot') format('embedded-opentype'),
		url('/wp-content/plugins/ultimate_vc_addons/assets/fonts/ult-vid-cntrl.woff_33ace239') format('woff'),
		url('/wp-content/plugins/ultimate_vc_addons/assets/fonts/ult-vid-cntrl.ttf_33ace239') format('truetype'),
		url('/wp-content/plugins/ultimate_vc_addons/assets/fonts/ult-vid-cntrl.svg_33ace239') format('svg');
	font-weight: normal;
	font-style: normal;
}

[class^="ult-vid-cntrl"], [class*=" ult-vid-cntrl"] {
	font-family: 'ult-vid-cntrl';
	speak: none;
	font-style: normal;
	font-weight: normal;
	font-variant: normal;
	text-transform: none;
	line-height: 1;

	/* Better Font Rendering =========== */
	-webkit-font-smoothing: antialiased;
	-moz-osx-font-smoothing: grayscale;
}

.ult-vid-cntrlplay:before {
	content: "\e600";
}
.ult-vid-cntrlpause:before {
	content: "\e601";
}
